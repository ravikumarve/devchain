# ═══════════════════════════════════════════════
# DevChain Environment Variables
# ═══════════════════════════════════════════════
# REQUIRED variables will cause the server to exit on startup if missing.
# Copy this file to .env and fill in your values.

# ─── Server ────────────────────────────────────
NODE_ENV=development
PORT=10000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=debug                          # debug | info | warn | error

# ─── Database (Prisma / PostgreSQL) ─────────────
# REQUIRED: Use Supabase Pooler for Vercel (port 5432 for session, 6543 for transaction)
DATABASE_URL=postgresql://postgres.project_ref:password@aws-0-region.pooler.supabase.com:5432/postgres

# ─── Supabase (Auth + File Storage) ─────────────
# REQUIRED — now handles ALL authentication (no custom JWT needed)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here    # NEVER expose to frontend (admin client)

# Optional: anon key for client-side operations (falls back to service_role if missing)
# SUPABASE_ANON_KEY=your-anon-key-here

# ─── Stripe Payments ────────────────────────────
# Required for payment processing
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here

# ─── Ownership Certificates ─────────────────────
# Secret used for SHA-256 ownership hash generation
OWNERSHIP_HASH_SECRET=devchain-ownership-secret

# ─── SMTP Email ─────────────────────────────────
# Optional — emails silently skip if not configured
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ─── Frontend ───────────────────────────────────
VITE_API_URL=http://localhost:10000
