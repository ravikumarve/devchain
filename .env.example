# ═══════════════════════════════════════════════
# DevChain Environment Variables
# ═══════════════════════════════════════════════
# REQUIRED variables will cause the server to exit on startup if missing.
# Copy this file to .env and fill in your values.

# ─── Server ────────────────────────────────────
NODE_ENV=development
PORT=10000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=debug                          # debug | info | warn | error

# ─── Database (Prisma / PostgreSQL) ─────────────
# REQUIRED
DATABASE_URL=postgresql://user:password@localhost:5432/devchain

# ─── JWT Authentication ─────────────────────────
# REQUIRED: JWT_SECRET (min 32 random characters)
JWT_SECRET=change-this-to-a-32-char-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Optional: if not set, derived from JWT_SECRET (less secure)
# JWT_REFRESH_SECRET=

# ─── Supabase (File Storage) ────────────────────
# REQUIRED
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here    # NEVER expose to frontend

# ─── Stripe Payments ────────────────────────────
# Required for payment processing
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here

# ─── Ownership Certificates ─────────────────────
# Secret used for SHA-256 ownership hash generation
OWNERSHIP_HASH_SECRET=devchain-ownership-secret

# ─── SMTP Email ─────────────────────────────────
# Optional — emails silently skip if not configured
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ─── Frontend (Expo) ────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:10000
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
