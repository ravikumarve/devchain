# ─── Backend ──────────────────────────────────────
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# ─── Supabase (PostgreSQL) ────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # NEVER expose to frontend

# ─── JWT Auth ─────────────────────────────────────
JWT_SECRET=minimum-32-character-random-secret-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Firebase Storage ─────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-bucket.appspot.com
FIREBASE_SERVICE_ACCOUNT_KEY=your-base64-encoded-key

# ─── Upstash Redis ────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ─── Stripe Payments ──────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here
STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# ─── Frontend (Expo) ──────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
