{
  "buildCommand": "npm run vercel-build",
  "installCommand": "npm install",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...path]" },
    { "source": "/(.*)", "destination": "/apps/web/dist/index.html" }
  ],
  "functions": {
    "api/[...path].js": {
      "memory": 512,
      "maxDuration": 30
    }
  }
}
